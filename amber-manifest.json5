{
  manifest_version: "0.1.0",

  // CyberGym green consumes slots.proxy → this agent’s A2A export.
  slots: {
    proxy: { kind: "a2a", optional: true },
  },

  // Deploy-time secrets and URLs for pbfuzz-purple (pbfuzz + Cursor CLI A2A bridge for CyberGym level3).
  // Provide cursor_auth (base64 auth.json) for cursor-agent (see README).
  config_schema: {
    type: "object",
    properties: {
      cursor_auth: {
        type: "string",
        secret: true,
        description: "Standard base64 of the host file ~/.config/cursor/auth.json (raw bytes). Server decodes and writes $HOME/.config/cursor/auth.json.",
      },
      cursor_model: {
        type: "string",
        default: "gpt-5.4-mini-medium",
        description: "Optional. Passed to cursor-agent as --model (e.g. haiku-4.5); also used as PBFUZZ_LLM_MODEL when set.",
      },
    },
    required: ["cursor_auth"],
    additionalProperties: false,
  },

  program: {
    // Replace after publishing to GHCR (or use your registry namespace).
    image: "ghcr.io/sgzeng/pbfuzz-purple:latest",
    entrypoint: [
      "uv",
      "run",
      "src/server.py",
      "--host",
      "0.0.0.0",
    ],

    env: {
      PYTHONUNBUFFERED: "1",
      HOME: "/home/agent",
      // fallback package lives at /home/agent/fallback — must be on PYTHONPATH even if the runtime
      // injects env from this manifest rather than inheriting Docker's ENV layer.
      PYTHONPATH: "/home/agent:/home/agent/pbfuzz",
      // Amber / runtimes may override PORT; keep network.endpoints.port in sync with this default.
      PORT: "9029",
      CURSOR_AUTH: "${config.cursor_auth}",
      CURSOR_MODEL: "${config.cursor_model}",
      PBFUZZ_LLM_MODEL: "${config.cursor_model}",
      // Match docker-compose: large A2A bodies; override in a fork if needed.
      CYBERGYM_TASK_ID: "arvo:47101",
      MAX_OUTER_ROUNDS: "3",
      MAX_INNER_ITER: "10",
      A2A_MAX_CONTENT_LENGTH: "0",
      PURPLE_OUTPUT_HOST: "off",
    },

    network: {
      endpoints: [{ name: "a2a_endpoint", port: 9029 }],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },

  metadata: {
    description: "Purple CyberGym agent: pbfuzz workflow (INIT → PLAN→SUCCESS) + outer loop bridged to cursor-agent for PoC generation; pairs with cybergym-green (green consumes slots.proxy → this a2a endpoint).",
    authentication_note: "Set config.cursor_auth (base64 auth.json).",
    participant_roles: ["agent"],
  },
}
